{
  "name": "turf-debug-viz",
  "version": "0.0.1",
  "description": "Debug visualization tool for turfjs",
  "license": "MIT",
  "author": "Brendan Ratter",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "pnpm build:client && pnpm build:assets",
    "build:client": "esbuild src/client/index.ts --bundle --sourcemap --outfile=public/assets/client.js",
    "build:assets": "cpx 'src/client/style.css' public/assets && cpx 'vendor/*' public/assets && cpx 'node_modules/@turf/turf/turf.min.js' public/assets/",
    "watch": "concurrently -n client,assets,server -c magenta,cyan,yellow \"pnpm watch:client\" \"pnpm watch:assets\" \"pnpm watch:server\"",
    "watch:client": "esbuild src/client/index.ts --watch --bundle --sourcemap --outfile=public/assets/client.js",
    "watch:assets": "concurrently \"cpx 'src/client/style.css' public/assets --watch --verbose\" \"cpx 'vendor/*' public/assets --watch --verbose\"",
    "watch:server": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "format": "prettier --write src/**/*",
    "test:lint": "tsx node_modules/tape/bin/tape 'src/lint/**/*.test.ts'",
    "test:diff": "tsx node_modules/tape/bin/tape 'src/diff/**/*.test.ts'",
    "test:viz": "tsx --import ./src/debug-hook.ts src/client/test/run.ts"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.11",
    "@types/deasync": "^0.1.5",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^25.0.3",
    "@types/tape": "^5.8.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cpx2": "^8.0.0",
    "esbuild": "^0.27.2",
    "prettier": "^3.8.1",
    "tape": "^5.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@turf/turf": "^7.3.2",
    "d3-selection": "^3.0.0",
    "deasync": "^0.1.31",
    "ws": "^8.19.0"
  }
}
